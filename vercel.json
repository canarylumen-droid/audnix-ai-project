{
    "crons": [
        {
            "path": "/api/cron/tick",
            "schedule": "*/10 * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/client/index.html"
        }
    ]
}